#1. Create a Circle class and calculate area.
class Circle:
    def __init__(self, r):
        self.radius=r
    def area(self):
        print(self.radius**2)
c1=Circle(23)
c2=Circle(11)
c3=Circle(32)
c2.area()

#2. Create a Book class with title and author and display details.
class Book:
    def __init__(self, t,a):
        self.title=t
        self.author=a
    def display(self):
        print("Title:",self.title,end=", ")
        print("Author:",self.author)
