'''5.Rectangle Area
	Create a Rectangle class with:
	length
	breadth 
        Create a method area() to calculate and print the area.'''
class Rectangle():
    def __init__(self,l,b):
        self.length=l
        self.breadth=b
    def area(self):
        a=self.length*self.breadth
        print(a)
r1=Rectangle(12,21)
r2=Rectangle(2,3)
r3=Rectangle(11,44)
r1.area()
r2.area()

