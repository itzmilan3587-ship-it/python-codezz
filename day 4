#4.Write a Python program to count how many times each element occurs in a list using a dictionary.
l=[1, 2, 3, 2, 1, 4, 2, 3, 1]
dict={}
for i in l:
    if i in dict:
        dict[i]+=1
    else:
        dict[i]=1
for i,j in dict.items():
    print(i,j)

