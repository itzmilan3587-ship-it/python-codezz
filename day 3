#1.Write a function to check whether a given number is a palindrome.
def pal(a):
    copy=a
    fin=0
    while copy>0:
        fin=(fin*10)+(copy%10)
        copy//=10
    return a==fin
print(pal(int(input())))

#2.Write a function to count the number of vowels in a string.
def vowel(a):
    vow=['a','e','i','o','u']
    count=0
    for i in range(0,len(a)):
        if a[i] in vow:
            count+=1
    return count
print(vowel(input()))

