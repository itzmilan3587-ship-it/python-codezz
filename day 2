#9. Write a Python program to count the number of even and odd numbers from 1 to N.
num=int(input())
odd=0
even=0
for i in range(1,num+1):
    if i%2==0:
        even+=1
    else:
        odd+=1
print("even count =",even)
print("odd count =",odd)

#10. Write a Python program to reverse the digits of a given number using arithmetic operators and loops.
num=int(input())
res=0
while num>0:
    last=num%10
    res=res*10+last
    num//=10
print(res)


