#9.Separate even and odd numbers into two different lists.
l=[10, 20, 90, 23,65,11]
even=[]
odd=[]
for i in l:
    if i%2==0:
        even.append(i)
    else:
        odd.append(i)
print("Even: ",even)
print("Odd: ",odd)

#10.Find the second largest element in a list.
l=[10, 20, 90, 23,65,11]
l2=[]
a=max(l)
for i in l:
    if i==a:
        continue
    else:
        l2.append(i)
print(max(l2))


















