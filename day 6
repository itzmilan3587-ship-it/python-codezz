#4. Write a program that raises a custom exception if marks are not between 0 and 100
class MarkException(Exception):
    pass
try:
    m=int(input())
    if m<0 or m>100:
        raise MarkException("Plz enter the correct mark")
    print("You are mark:",m)
except MarkException as m:
    print(m)

#5. Write a program that raises a custom exception if a user enters a negative number
class NegException(Exception):
    pass
try:
    num=int(input("Enter: "))
    if num<0:
        raise NegException("Enter number 0 or above 0")
    print("Your number:",num)
except NegException as n:
    print(n)

#6. Create a class Shape with method area(). Override it in classes Rectangle and Circle
class Shape:
    def area(self):
        print("Area of shape")
class Rectangle(Shape):
    def area(self):
        l=int(input("Length: "))
        b=int(input("Breadth: "))
        print("Area of rectangle: ",l*b)
class Circle(Shape):
    def area(self):
        r=int(input("Radius: "))
        print("Area of rectangle: ",r*r)
rec=Rectangle()
rec.area()
cir=Circle()
cir.area()

#7. Write a program to count the number of vowels in a text file
f=open("Text_Ex.txt","r")
w=f.read().lower()
vowels=['a','e','i','o','u']
count=0
for ch in w:
    if ch in vowels:
        count+=1
print(count)
f.close()

#8. Write a program to write student details into a text file from csv file
